{
  "name": "gemini-avatar",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/gemini-avatar.umd.js",
  "module": "./dist/gemini-avatar.es.js",
  "exports": {
    ".": {
      "import": "./dist/gemini-avatar.es.js",
      "require": "./dist/gemini-avatar.umd.js"
    }
  },
  "files": [
    "dist",
    "src/assets"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "gts lint",
    "fix": "gts fix",
    "prepare": "husky",
    "clean": "gts clean",
    "compile": "tsc",
    "pretest": "npm run compile",
    "posttest": "npm run lint"
  },
  "devDependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitest/coverage-v8": "^1.6.1",
    "gts": "^7.0.0",
    "happy-dom": "^14.12.3",
    "husky": "^9.0.11",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.3.3",
    "vite": "^5.4.21",
    "vitest": "^1.4.0",
    "@types/node": "^22.7.5"
  },
  "dependencies": {
    "mpegts.js": "^1.7.3"
  }
}
