{
  "name": "gemini-avatar",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/gemini-avatar.umd.js",
  "module": "./dist/gemini-avatar.es.js",
  "exports": {
    ".": {
      "import": "./dist/gemini-avatar.es.js",
      "require": "./dist/gemini-avatar.umd.js"
    }
  },
  "files": [
    "dist",
    "src/assets"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "gts lint",
    "fix": "gts fix",
    "prepare": "husky",
    "clean": "gts clean",
    "compile": "tsc",
    "posttest": "npm run lint"
  },
  "devDependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "gts": "^7.0.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.0.11",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "mpegts.js": "^1.7.3"
  }
}
